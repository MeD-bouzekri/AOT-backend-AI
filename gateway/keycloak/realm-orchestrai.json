      "realmRoles": ["it_admin"],
      "attributes": { "department": ["it"] }
    },
    {
      "username": "finance1", "enabled": true, "email": "sofiane.mansouri@numidia.ia",
      "firstName": "Sofiane", "lastName": "Mansouri",
      "credentials": [{ "type": "password", "value": "finance1", "temporary": false }],
      "realmRoles": ["finance_admin"],
      "attributes": { "department": ["finance"] }
    },
    {
