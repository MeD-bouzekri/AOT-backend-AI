    },
    {
      "username": "cfo", "enabled": true, "email": "mohamed.bouzekri@numidia.ia",
      "firstName": "Mohamed", "lastName": "Bouzekri",
      "credentials": [{ "type": "password", "value": "cfo", "temporary": false }],
      "realmRoles": ["cfo", "finance_admin"],
